<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".ObatActivity">

    <LinearLayout
        android:id="@+id/headerObat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#4CAF50"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💊 Data Obat"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="24sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kelola Stok dan Data Obat"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>

    </LinearLayout>

    <EditText
        android:id="@+id/edtCariObat"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/headerObat"
        android:layout_margin="16dp"
        android:hint="Cari Nama Obat"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"
        android:inputType="text"
        android:imeOptions="actionSearch" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvObat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/edtCariObat"
        android:layout_marginHorizontal="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabTambahObat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#4CAF50"
        app:tint="@android:color/white"
        android:contentDescription="Tambah Obat" />

</RelativeLayout>