<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".PasienActivity">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👨 Data Pasien"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="24sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kelola Data Pasien Klinik"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>

    </LinearLayout>

    <EditText
        android:id="@+id/edtCari"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/header"
        android:layout_margin="16dp"
        android:hint="Cari Nama Pasien"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"
        android:inputType="text"
        android:importantForAutofill="no" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPasien"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/edtCari"
        android:layout_marginHorizontal="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabTambah"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#1976D2"
        app:tint="@android:color/white"
        android:contentDescription="Tambah Pasien" />

</RelativeLayout>