<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Edit Antrian"
            android:textStyle="bold"
            android:textSize="26sp"
            android:textColor="#1565C0"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Silahkan perbarui data antrian"
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- Nomor Antrian -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nomor Antrian"/>

        <EditText
            android:id="@+id/edtNomor"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Contoh : A001"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"/>

        <!-- Pasien -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pasien"
            android:layout_marginTop="15dp"/>

        <Spinner
            android:id="@+id/spPasien"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <!-- Dokter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dokter"
            android:layout_marginTop="15dp"/>

        <Spinner
            android:id="@+id/spDokter"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <!-- Tanggal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tanggal"
            android:layout_marginTop="15dp"/>

        <EditText
            android:id="@+id/edtTanggal"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:focusable="false"
            android:clickable="true"
            android:hint="Pilih Tanggal"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"/>

        <!-- Jam -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jam"
            android:layout_marginTop="15dp"/>

        <EditText
            android:id="@+id/edtJam"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:focusable="false"
            android:clickable="true"
            android:hint="Pilih Jam"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"/>

        <!-- Status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:layout_marginTop="15dp"/>

        <Spinner
            android:id="@+id/spStatus"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <!-- Tombol Update -->
        <Button
            android:id="@+id/btnUpdate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:text="🔄 Update Data"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1976D2"/>

    </LinearLayout>

</ScrollView>