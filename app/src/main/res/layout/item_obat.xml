<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtNamaObat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Obat"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"/>

        <TextView
            android:id="@+id/txtJenisObat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jenis: Tablet"
            android:textColor="#666666"/>

        <TextView
            android:id="@+id/txtHarga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harga: Rp 10.000"
            android:textColor="#666666"/>

        <TextView
            android:id="@+id/txtStok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stok: 100"
            android:textColor="#666666"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="10dp">

            <ImageButton
                android:id="@+id/btnEditObat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#4CAF50"/>

            <ImageButton
                android:id="@+id/btnHapusObat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#F44336"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>